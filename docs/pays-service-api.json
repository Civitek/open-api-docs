              "echeck"
            ]
          },
          "shopperPaymentInfo": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "description": "To make a payment using a stored payment method, provide storedPaymentMethodId instead of this field. Otherwise, provide the payment details required to process the payment. Expected fields depend on payment.type. For 'creditcard', required keys are: encryptedCardNumber, encryptedSecurityCode, encryptedExpiryMonth, encryptedExpiryYear, and cardHolderName. For 'echeck', required keys are: accountNumber, routingNumber, and either firstName and lastName, or businessName."
            },
            "description": "To make a payment using a stored payment method, provide storedPaymentMethodId instead of this field. Otherwise, provide the payment details required to process the payment. Expected fields depend on payment.type. For 'creditcard', required keys are: encryptedCardNumber, encryptedSecurityCode, encryptedExpiryMonth, encryptedExpiryYear, and cardHolderName. For 'echeck', required keys are: accountNumber, routingNumber, and either firstName and lastName, or businessName."
          },
          "storePaymentMethod": {
            "type": "boolean",
            "description": "Whether the newly entered payment method should be stored for future use."
          }
        },
