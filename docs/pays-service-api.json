            "example": "success",
            "enum": [
              "success",
              "failed"
            ]
          },
          "statusCode": {
            "type": "integer",
            "description": "Http status code",
            "format": "int32"
          },
          "message": {
            "type": "string",
            "description": "Success message"
          },
          "errorDetails": {
            "type": "string",
            "description": "Error details when status is failed"
          }
