      "Payment": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Type of payment method.",
            "enum": [
              "creditcard",
              "echeck"
            ]
          },
          "shopperPaymentInfo": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "description": "Payment details as key-value pairs, based on the selected payment type. If type is 'creditcard', required keys are: encryptedCardNumber, encryptedSecurityCode, encryptedExpiryMonth, encryptedExpiryYear, cardHolderName. If type is 'echeck', required keys are: accountNumber, routingNumber, and either (firstName, lastName) or businessName."
            },
            "description": "Payment details as key-value pairs, based on the selected payment type. If type is 'creditcard', required keys are: encryptedCardNumber, encryptedSecurityCode, encryptedExpiryMonth, encryptedExpiryYear, cardHolderName. If type is 'echeck', required keys are: accountNumber, routingNumber, and either (firstName, lastName) or businessName."
          },
          "paymentProcess": {
            "type": "string",
            "description": "Specifies the payment process. Must be 'subscription_tokenization' when performing payment method tokenization.",
            "enum": [
              "subscription_tokenization"
            ]
          }
        },
        "description": "Payment method data"
      },
      "PaymentRequest": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "description": "List of items to be paid for. Do not include this field when the request is intended only for payment method tokenization.",
            "items": {
              "$ref": "#/components/schemas/Item"
            }
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "customer": {
            "$ref": "#/components/schemas/Customer"
          },
          "payment": {
            "$ref": "#/components/schemas/Payment"
          },
          "paymentReference": {
            "type": "string",
            "description": "A secure, tokenized identifier for a stored payment method such as a credit card or bank account."
          },
          "subscriptionId": {
            "type": "string",
            "description": "The unique subscription ID linked to the customer for which the payment method is used."
          }
        }
      },
      "TpePaymentResponse": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "integer",
            "description": "This is a unique identifier for the payment transaction.",
            "format": "int64"
          },
          "subscriptionId": {
            "type": "string",
            "description": "The unique subscription ID linked to the customer."
          },
          "status": {
            "type": "string",
            "description": "Status of the order",
            "example": "success",
            "enum": [
              "success",
              "failed"
            ]
          },
          "errorMessage": {
            "type": "string",
            "description": "This is an error message returned in case the OrderId could not be created. This will be null if the OrderId was created successfully."
          },
          "errorDetails": {
            "type": "string"
          },
          "retry": {
            "type": "boolean"
          },
          "review": {
            "type": "boolean"
          }
        }
      },

      "PaymentMethodsRequest": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          }
        }
      },
      "PaymentMethod": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "totalAmount": {
            "type": "number"
          },
          "config": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "fee": {
            "$ref": "#/components/schemas/PaymentMethodFee"
          }
        }
      },
      "PaymentMethodFee": {
        "type": "object",
        "properties": {
          "itemKey": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          }
        }
      },
      "PaymentMethodsResponse": {
        "type": "object",
        "properties": {
          "environment": {
            "type": "string"
          },
          "paymentMethods": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PaymentMethod"
            }
          }
        }
      }


		},
		"securitySchemes": {
			"bearerAuth": {
				"type": "http",
				"scheme": "bearer",
				"bearerFormat": "JWT",
				"description": "Use the JWT access token issued by the TPE Auth server. Obtain a token via the TPE Auth API (see https://civitek.github.io/open-api-docs/tpe-auth.html) then include it as: Authorization: Bearer <token>"
			}
		}
	}
}