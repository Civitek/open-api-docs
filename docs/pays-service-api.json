          "item": {
            "$ref": "#/components/schemas/Item"
          },
          "recurringFrequency": {
            "type": "string",
            "description": "Payment recurrence frequency",
            "enum": [
              "DAILY",
              "WEEKLY",
              "MONTHLY",
              "BI_WEEKLY",
              "BI_MONTHLY",
              "ANNUALLY"
            ]
          },
          "recurringStartDate": {
            "type": "string",
            "description": "The start date of the recurring schedule.",
            "format": "date"
          },
          "recurringEndDate": {
            "type": "string",
            "description": "The end date of the recurring schedule.",
            "format": "date"
          }
        }
