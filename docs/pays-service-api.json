          "retry": {
            "type": "boolean",
            "description": "Indicates whether the payment attempt can be retried.",
            "example": true
          },
          "review": {
            "type": "boolean",
            "description": "Indicates whether the transaction requires manual review.",
            "example": false
          }
        },
        "description": "Response returned after a payment transaction is processed.\n\nFor successful payments, orderId and status are returned.\n\nIf the payment method was requested to be stored, storePaymentMethodStatus indicates whether the payment method was stored successfully.\n\nIf the transaction fails, errorMessage and errorDetails may be returned.\n\nretry indicates whether the payment attempt can be retried, and review indicates whether the transaction requires manual review."
      },
