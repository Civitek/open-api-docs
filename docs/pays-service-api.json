"paths": {
    "/subscription/getPaymentMethods": {
      "post": {
        "tags": [
          "Subscription Service"
        ],
        "summary": "Retrieves saved payment methods",
        "description": "Gets the saved payment methods associated with a subscriptionId",
        "operationId": "findSavedPaymentMethods",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SavedPaymentMethodRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Payment methods successfully retrieved",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedPaymentsMethodsResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedPaymentsMethodsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedPaymentsMethodsResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/subscription/deletePaymentMethod": {
      "post": {
        "tags": [
          "Subscription Service"
        ],
        "summary": "Deletes a saved payment method",
        "description": "Deletes the saved payment associated with a referenceId",
        "operationId": "deleteSavedPaymentMethod",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeleteSavedPaymentMethodRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Payment method deleted",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/subscription/addIdentity": {
      "post": {
        "tags": [
          "Subscription Service"
        ],
        "summary": "Adds identities to the subscription",
        "description": "Adds identities and associates them with a subscriptionId, while overwritting the previously added identities",
        "operationId": "addIdentity",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscriptionIdentitiesRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Identities added",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/recurring/setup": {
      "post": {
        "tags": [
          "Recurring Service"
        ],
        "summary": "Create recurring payment configuration",
        "description": "Sets up a subscription-like recurring payment with defined amount, frequency, and payment method.",
        "operationId": "setup",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecurringRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Setup completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecurringResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/recurring/details": {
      "post": {
        "tags": [
          "Recurring Service"
        ],
        "summary": "Get recurring payment details",
        "description": "Retrieves the configuration and status of a recurring payment using the provided recurring ID.",
        "operationId": "details",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecurringDetailsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "404": {
            "description": "Recurring payment not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "200": {
            "description": "Recurring payment details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecurringDetailsResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/recurring/cancel": {
      "post": {
        "tags": [
          "Recurring Service"
        ],
        "summary": "Cancel recurring payment",
        "description": "Cancels an active recurring payment and stops future billing cycles for the specified recurring ID.",
        "operationId": "cancel",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecurringCancelRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "404": {
            "description": "Recurring payment not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "200": {
            "description": "Recurring payment cancelled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecurringCancelResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/payment/process": {
      "post": {
        "tags": [
          "Payment Service"
        ],
        "summary": "Process a payment transaction",
        "description": "Accepts payment details and processes the transaction. ",
        "operationId": "processPayment",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TpePaymentResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/payment/paymentMethods": {
      "post": {
        "tags": [
          "Payment Service"
        ],
        "summary": "Retrieve payment methods",
        "description": "Returns a list of stored payment methods for the given subscription ID, along with their corresponding fees.",
        "operationId": "getpaymentMethods",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentMethodsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentMethodsResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    }
  },
	 "components": {
    "schemas": {
      "SavedPaymentMethodRequest": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "string",
            "description": "SubscritionId associated with saved payments."
          }
        }
      },
      "SavedPayment": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Saved payment type: creditcard oe echeck."
          },
          "info": {
            "$ref": "#/components/schemas/SavedPaymentInfo"
          }
        },
        "description": "Saved payment methods"
      },
      "SavedPaymentInfo": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string",
            "description": "Summary that describes the specific payment."
          },
          "reference": {
            "type": "string",
            "description": "ReferenceId that identifies this specific saved payment method."
          },
          "expiresOn": {
            "type": "string",
            "description": "Expiration date for a credit card."
          },
          "expired": {
            "type": "boolean",
            "description": "Expiration flag to alert the user that a credit card has expired."
          }
        },
        "description": "Saved payment information."
      },
      "SavedPaymentsMethodsResponse": {
        "type": "object",
        "properties": {
          "methods": {
            "type": "array",
            "description": "Saved payment methods",
            "items": {
              "$ref": "#/components/schemas/SavedPayment"
            }
          },
          "subscriptionId": {
            "type": "string",
            "description": "Subscription Id"
          },
          "storedPaymentMethodId": {
            "type": "string",
            "description": "Identifies a specific stored payment"
          },
          "status": {
            "type": "string",
            "description": "Status: success or failed"
          },
          "statusCode": {
            "type": "string",
            "description": "Http status code"
          },
          "message": {
            "type": "string",
            "description": "Success message"
          },
          "responseTimeStamp": {
            "type": "string",
            "description": "Date of response",
            "format": "date-time"
          },
          "errorDetails": {
            "type": "string",
            "description": "Error response message"
          }
        }
      },
      "DeleteSavedPaymentMethodRequest": {
        "type": "object",
        "properties": {
          "storedPaymentMethodId": {
            "type": "string",
            "description": "Id associated with a specific saved payment."
          }
        }
      },
      "SubscriptionResponse": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "string",
            "description": "Subscription Id"
          },
          "storedPaymentMethodId": {
            "type": "string",
            "description": "Identifies a specific stored payment"
          },
          "status": {
            "type": "string",
            "description": "Status: success or failed"
          },
          "statusCode": {
            "type": "string",
            "description": "Http status code"
          },
          "message": {
            "type": "string",
            "description": "Success message"
          },
          "responseTimeStamp": {
            "type": "string",
            "description": "Date of response",
            "format": "date-time"
          },
          "errorDetails": {
            "type": "string",
            "description": "Error details when status is failed"
          }
        }
      },
      "CustomerIdentity": {
        "type": "object",
        "properties": {
          "identityTypeId": {
            "type": "integer",
            "description": "Valid values: 1=SSN, 2=Passport, 4=Alien Registration Number for Identity One; 0=Other, 3=Driver’s License for Identity Two",
            "format": "int32",
            "example": 1
          },
          "value": {
            "type": "string"
          },
          "countryCode": {
            "type": "string",
            "description": "Country code",
            "example": "US"
          },
          "region": {
            "type": "string",
            "description": "Region/state code",
            "example": "CA"
          }
        },
        "description": "Identities that will be associated with SubscriptionId."
      },
      "SubscriptionIdentitiesRequest": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "string",
            "description": "SubscriptionId associated with saved payment information."
          },
          "identities": {
            "type": "array",
            "description": "Identities that will be associated with SubscriptionId.",
            "items": {
              "$ref": "#/components/schemas/CustomerIdentity"
            }
          }
        }
      },
      "AuthToken": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer",
            "format": "int32"
          },
          "refresh_token": {
            "type": "string"
          }
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "itemKey": {
            "type": "string",
